                    <div class="p-6 md:p-8 md:col-span-7 flex flex-col justify-between">
                        <div>
                            <!-- Header / Badge -->
                            <div class="flex flex-wrap items-center gap-2 mb-4">
                                <span class="bg-amber-400/10 border border-amber-400/20 text-amber-400 text-[10px] font-black uppercase px-2.5 py-1 rounded-full">
                                    Mekan #${currentSlideIndex}
                                </span>
                                <span class="bg-slate-800 text-slate-300 text-[10px] font-bold px-2.5 py-1 rounded-full">
                                    ${venue.tag}
                                </span>
                            </div>

                            <!-- Name -->
                            <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white mb-2">
                                <span class="text-transparent bg-clip-text bg-gradient-to-r ${venue.color}">${venue.rank}</span> ${venue.name}
                            </h2>

                            <!-- Stars & Rating -->
                            <div class="flex items-center gap-2 mb-4">
                                <div class="flex text-sm">${starsHtml}</div>
                                <span class="text-slate-200 font-extrabold text-sm ml-1">${venue.score} / 10</span>
                            </div>

                            <!-- Summary -->
                            <p class="text-slate-400 text-xs md:text-sm leading-relaxed mb-6">
                                ${venue.summary}
                            </p>

                            <!-- Pros List -->
                            <div class="space-y-3">
                                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Öne Çıkan Artıları</h4>
                                <ul class="space-y-2.5">
                                    ${prosHtml}
                                </ul>
                            </div>
                        </div>

                        <!-- Verdict Card -->
                        <div class="mt-6 p-4 rounded-2xl bg-slate-950/60 border border-slate-800 flex items-center justify-between gap-3">
                            <div>
                                <h5 class="text-[10px] font-black uppercase text-amber-500 tracking-wider">Benim Notum</h5>
                                <p class="text-slate-300 text-xs md:text-sm font-semibold mt-0.5">${venue.verdict}</p>
                            </div>
                            <button onclick="addQuickVote(${venue.id})" class="shrink-0 bg-slate-900 hover:bg-slate-800 text-rose-400 hover:text-rose-300 p-2.5 rounded-xl border border-slate-800 hover:border-rose-500/20 transition-all text-xs flex items-center gap-1.5 font-bold">
                                <i class="fa-solid fa-heart"></i> <span id="quick-vote-btn-text-${venue.id}">Oy Ver</span>
                            </button>
                        </div>
                    </div>

                    <!-- Right Side Decorative / Image Sketch Placeholder -->
                    <div class="md:col-span-5 bg-gradient-to-br ${venue.color}/10 border-t md:border-t-0 md:border-l border-slate-800/80 p-8 flex flex-col justify-center items-center text-center relative overflow-hidden min-h-[220px] md:min-h-0">
                        <!-- Abstract Art Grid Pattern overlay -->
                        <div class="absolute inset-0 bg-[linear-gradient(to_right,#0000000a_1px,transparent_1px),linear-gradient(to_bottom,#0000000a_1px,transparent_1px)] bg-[size:14px_24px] opacity-20"></div>
                        
                        <div class="relative z-10">
                            <!-- Circular Graphic -->
                            <div class="w-20 h-20 rounded-full bg-gradient-to-tr ${venue.color} p-0.5 mb-4 mx-auto shadow-lg shadow-amber-500/10 flex items-center justify-center">
                                <div class="w-full h-full rounded-full bg-slate-950 flex items-center justify-center text-2xl">
                                    ${venue.id === 1 ? '🥇' : venue.id === 2 ? '🥈' : venue.id === 3 ? '🥉' : '🍽️'}
                                </div>
                            </div>
                            <span class="text-[11px] font-bold text-slate-400 block mb-1">Görsel Atmosfer Taslağı</span>
                            <p class="text-slate-200 text-sm font-extrabold max-w-[180px] mx-auto leading-snug">
                                ${venue.imagePlaceholder}
                            </p>
                        </div>
                    </div>
                </div>
            `;

            document.getElementById('slide-indicator').innerText = `${currentSlideIndex} / 7`;
        }

        // Slide Navigation functions
        function nextSlide() {
            if (currentSlideIndex < 8) {
                currentSlideIndex++;
                renderSlide();
            } else {
                // If on final comparison slide, jump to vote mode
                setMode('vote');
            }
        }

        function prevSlide() {
            if (currentSlideIndex > 0) {
                currentSlideIndex--;
                renderSlide();
            }
        }

        function goToVenueSlide(id) {
            setMode('slide');
            currentSlideIndex = id;
            renderSlide();
        }

        // Render Grid UI
        function renderGrid() {
            const gridContainer = document.getElementById('grid-content');
            gridContainer.innerHTML = '';

            venues.forEach(venue => {
                let starsHtml = '';
                const fullStars = Math.floor(venue.score / 2);
                for(let i=0; i<5; i++) {
                    starsHtml += (i < fullStars) ? `<i class="fa-solid fa-star text-amber-400"></i>` : `<i class="fa-regular fa-star text-slate-600"></i>`;
                }

                gridContainer.innerHTML += `
                    <div class="bg-slate-900/40 hover:bg-slate-900/60 rounded-2xl border border-slate-800/80 hover:border-slate-700/60 p-5 transition-all duration-300 flex flex-col justify-between hover:scale-[1.02] group shadow-lg" data-tag="${venue.tag}">
                        <div>
                            <!-- Header with rank/rating -->
                            <div class="flex justify-between items-start gap-2 mb-3">
                                <span class="bg-slate-950 text-slate-400 text-[10px] font-bold px-2.5 py-1 rounded-full border border-slate-800">
                                    ${venue.tag}
                                </span>
                                <div class="flex items-center gap-1.5 bg-amber-500/10 border border-amber-500/20 px-2 py-0.5 rounded-lg">
                                    <span class="text-amber-400 font-extrabold text-xs">${venue.score}</span>
                                </div>
                            </div>

                            <!-- Name -->
                            <h3 class="text-xl font-extrabold text-white group-hover:text-amber-400 transition-colors mb-2">
                                <span class="text-transparent bg-clip-text bg-gradient-to-r ${venue.color}">${venue.rank}</span> ${venue.name}
                            </h3>

                            <!-- Short Highlight -->
                            <p class="text-slate-400 text-xs mb-4 line-clamp-2">
                                ${venue.summary}
                            </p>
                        </div>

                        <!-- Footer actions inside grid card -->
                        <div class="border-t border-slate-800/60 pt-4 mt-4 flex items-center justify-between">
                            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-wider">Puan: ${venue.score}/10</span>
                            <button onclick="goToVenueSlide(${venue.id})" class="text-xs font-bold text-amber-500 group-hover:text-amber-400 transition-all flex items-center gap-1">
                                Detaylara Git <i class="fa-solid fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>
                `;
            });
        }

        // Filtering Logic for Grid Mode
        function filterVenues(tag) {
            // Update UI filter button states
            const buttons = document.querySelectorAll('.filter-btn');
            buttons.forEach(btn => {
                btn.classList.remove('bg-amber-500', 'text-slate-950');
                btn.classList.add('bg-slate-800', 'text-slate-400');
            });

            // Find current clicked button and activate it
            event.currentTarget.classList.remove('bg-slate-800', 'text-slate-400');
            event.currentTarget.classList.add('bg-amber-500', 'text-slate-950');

            // Filter cards
            const cards = document.querySelectorAll('#grid-content > div');
            let count = 0;
            
            cards.forEach(card => {
                const cardTag = card.getAttribute('data-tag');
                if (tag === 'all' || cardTag === tag) {
                    card.style.display = 'flex';
                    count++;
                } else {
                    card.style.display = 'none';
                }
            });

            document.getElementById('venue-count').innerText = count;
        }

        // Render Oylama/Karar Modu
        function renderVotingRows() {
            const container = document.getElementById('vote-cards-list');
            container.innerHTML = '';

            venues.forEach(v => {
                container.innerHTML += `
                    <div class="flex items-center justify-between p-3.5 md:p-4 rounded-xl bg-slate-950/60 border border-slate-800 hover:border-slate-700/60 transition-all gap-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-gradient-to-tr ${v.color} flex items-center justify-center text-lg font-black text-slate-950 shrink-0">
                                ${v.id === 1 ? '🥇' : v.id === 2 ? '🥈' : v.id === 3 ? '🥉' : '🍷'}
                            </div>
                            <div>
                                <h4 class="font-extrabold text-sm md:text-base text-white">${v.rank} ${v.name}</h4>
                                <p class="text-xs text-slate-400 hidden md:block">${v.highlight}</p>
                            </div>
                        </div>

                        <!-- Interactive Counter -->
                        <div class="flex items-center gap-4">
                            <!-- Display current vote amount -->
                            <div class="text-right">
                                <span class="text-[10px] font-bold uppercase text-slate-500 block">Ekip Oyu</span>
                                <span id="vote-count-${v.id}" class="text-lg font-black text-rose-400">${votes[v.id]} Oy</span>
                            </div>

                            <!-- Buttons to decrease or increase -->
                            <div class="flex gap-1.5">
                                <button onclick="changeVote(${v.id}, -1)" class="w-8 h-8 rounded-lg bg-slate-900 border border-slate-800 flex items-center justify-center text-slate-400 hover:text-rose-400 hover:border-rose-500/20 transition-all text-xs">
                                    <i class="fa-solid fa-minus"></i>
                                </button>
                                <button onclick="changeVote(${v.id}, 1)" class="w-8 h-8 rounded-lg bg-amber-500 text-slate-950 flex items-center justify-center hover:bg-amber-400 transition-all text-xs font-bold">
                                    <i class="fa-solid fa-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            });
        }

        function changeVote(id, amount) {
            if (votes[id] + amount >= 0) {
                votes[id] += amount;
                
                // Update local counts immediately on UI to avoid complete re-renders
                const countElem = document.getElementById(`vote-count-${id}`);
                if (countElem) {
                    countElem.innerText = `${votes[id]} Oy`;
                }

                // Update standard list render values
                const quickVoteText = document.getElementById(`quick-vote-btn-text-${id}`);
                if (quickVoteText) {
                    quickVoteText.innerText = votes[id] > 0 ? `${votes[id]} Oy Verildi` : 'Oy Ver';
                }
            }
        }

        function addQuickVote(id) {
            changeVote(id, 1);
            // Quick feedback indication
            const btnText = document.getElementById(`quick-vote-btn-text-${id}`);
            if (btnText) {
                btnText.innerHTML = `<span class="text-rose-400">❤️ +1 Oy Eklendi</span>`;
                setTimeout(() => {
                    btnText.innerText = `${votes[id]} Oy Verildi`;
                }, 1000);
            }
        }

        function resetVotes() {
            venues.forEach(v => {
                votes[v.id] = 0;
            });
            renderVotingRows();
        }

        // Show Modal with Winner
        function showWinner() {
            let winner = null;
            let maxVotes = -1;

            venues.forEach(v => {
                if (votes[v.id] > maxVotes) {
                    maxVotes = votes[v.id];
                    winner = v;
                }
            });

            // Prevent showing winner with zero votes
            if (maxVotes === 0) {
                // Show custom notification style inside modal or simply pick default rank 1
                winner = venues[0]; // fallback to Maziden
            }

            document.getElementById('winner-name').innerText = `${winner.rank} ${winner.name}`;
            document.getElementById('winner-votes').innerText = `${maxVotes} Oy`;
            document.getElementById('winner-quote').innerText = `"${winner.summary}" - Gruptaki herkes bu mekana hayran kalacak!`;

            // Open Modal
            const modal = document.getElementById('winner-modal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => {
                document.getElementById('winner-card').classList.remove('scale-95');
                document.getElementById('winner-card').classList.add('scale-100');
            }, 50);
        }

        function closeWinnerModal() {
            const modal = document.getElementById('winner-modal');
            document.getElementById('winner-card').classList.remove('scale-100');
            document.getElementById('winner-card').classList.add('scale-95');
            setTimeout(() => {
                modal.classList.remove('flex');
                modal.classList.add('hidden');
            }, 200);
        }

        // Navigation Modes switching
        function setMode(mode) {
            currentMode = mode;
            
            // Toggle container classes
            document.getElementById('slide-mode-container').classList.add('hidden');
            document.getElementById('grid-mode-container').classList.add('hidden');
            document.getElementById('vote-mode-container').classList.add('hidden');

            // Reset navigation header buttons styling
            const btnSlide = document.getElementById('btn-slide-mode');
            const btnGrid = document.getElementById('btn-grid-mode');
            const btnVote = document.getElementById('btn-vote-mode');

            [btnSlide, btnGrid, btnVote].forEach(btn => {
                btn.className = "px-4 py-2 rounded-lg text-sm font-semibold transition-all flex items-center gap-2 text-slate-400 hover:text-white";
            });

            if (mode === 'slide') {
                document.getElementById('slide-mode-container').classList.remove('hidden');
                btnSlide.className = "px-4 py-2 rounded-lg text-sm font-semibold transition-all flex items-center gap-2 bg-amber-500 text-slate-950 shadow-lg shadow-amber-500/20";
                renderSlide();
            } else if (mode === 'grid') {
                document.getElementById('grid-mode-container').classList.remove('hidden');
                btnGrid.className = "px-4 py-2 rounded-lg text-sm font-semibold transition-all flex items-center gap-2 bg-amber-500 text-slate-950 shadow-lg shadow-amber-500/20";
                renderGrid();
            } else if (mode === 'vote') {
                document.getElementById('vote-mode-container').classList.remove('hidden');
                btnVote.className = "px-4 py-2 rounded-lg text-sm font-semibold transition-all flex items-center gap-2 bg-gradient-to-r from-amber-500 to-rose-500 text-slate-950 shadow-lg shadow-rose-500/20";
                renderVotingRows();
            }
        }

        // Keyboard Arrow Controls
        document.addEventListener('keydown', (e) => {
            if (currentMode === 'slide') {
                if (e.key === 'ArrowRight') {
                    nextSlide();
                } else if (e.key === 'ArrowLeft') {
                    prevSlide();
                }
            }
        });

        // Touch Swipe support for Mobile
        let touchstartX = 0;
        let touchendX = 0;
        
        function checkDirection() {
            if (touchendX < touchstartX - 50) nextSlide(); // swiped left
            if (touchendX > touchstartX + 50) prevSlide(); // swiped right
        }

        document.addEventListener('touchstart', e => {
            touchstartX = e.changedTouches[0].screenX;
        });

        document.addEventListener('touchend', e => {
            touchendX = e.changedTouches[0].screenX;
            if (currentMode === 'slide') {
                checkDirection();
            }
        });

        // App Initial Launch
        window.onload = function() {
            renderSlide();
        };
    </script>
</body>
</html>

